// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}



model User {
  id            String    @id @default(uuid())
  email         String    @unique
  password      String
  name          String
  emailVerified Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  refreshToken  String?   @unique
  policy        Boolean   @default(false)
  isOnboarded   Boolean   @default(false)
  userType      UserType  @default(UNSET)
  //  EITHER SUPPLIER OR PLUG
  supplier      Supplier?
  plug          Plug?

  // Relations
  emailVerifications EmailVerification[]
  passwordTokens     PasswordToken[]

  @@index([email, name])
}

model EmailVerification {
  id      String   @id @default(cuid())
  token   String   @unique
  expires DateTime
  userId  String   @unique
  user    User     @relation(fields: [userId], references: [id])

  @@index([token])
}

model PasswordToken {
  id      String   @id @default(cuid())
  email   String
  token   String   @unique
  expires DateTime
  userId  String
  user    User     @relation(fields: [userId], references: [id])

  @@unique([email, token])
}

enum UserType {
  UNSET
  SUPPLIER
  PLUG
}

model Supplier {
  id           String    @id @default(cuid())
   businessName   String   @default("")                
  businessType String? 
   pickupLocation String    @default("")                  
  avatar         String?   
  userId       String    @unique
  user         User      @relation(fields: [userId], references: [id])
  products     Product[]
  verified     Boolean   @default(false)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model Plug {
  id              String   @id @default(cuid())
  businessName    String
  phone           String?
  state           String?
  aboutBusiness   String?
  niches          String[] // Array of strings
  // customNiche    String? 
  generalMerchant Boolean
  plugProduct  PlugProduct[]
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([businessName])
}

model Product {
  id              String   @id @default(cuid())
  name            String
  description     String
  price           Float
  // quantity        Int
  category        String?
  images          String? // Typically would store JSON or comma-separated strings with image paths
  supplierId      String
  //  tags            String? // JSON string containing keywords and name alternatives
  // supplier        Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  supplier        Supplier @relation(fields: [supplierId], references: [id])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

   // indexes to improve query performance
  @@index([price])
  @@index([category])
  @@index([createdAt])
  @@index([supplierId])
  // Compound index for common filter combinations
  @@index([category, price])
 }



model PlugProduct {
  id               String        @id @default(cuid())
  originalId       String
  plugId           String
  price            Float
  pendingPrice     Float?        // New field for scheduled price
  priceEffectiveAt DateTime?     // New field for effective date
  status           ProductStatus @default(ACTIVE)
  plug             Plug          @relation(fields: [plugId], references: [id], onDelete: Cascade)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@unique([plugId, originalId])
  @@index([plugId])
  @@index([originalId])
}

enum ProductStatus {
  ACTIVE       // Original Product is active and available to plug into
  INACTIVE       // Original product is not available to plug into
}
