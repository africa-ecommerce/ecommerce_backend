// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}



model User {
  id            String    @id @default(uuid())
  email         String    @unique
  password      String
  name          String
  emailVerified Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  refreshToken  String?   @unique
  policy        Boolean   @default(false)
  isOnboarded   Boolean   @default(false)
  userType      UserType  @default(UNSET)
  //  EITHER SUPPLIER OR PLUG
  supplier      Supplier?
  plug          Plug?

  // Relations
  emailVerifications EmailVerification[]
  passwordTokens     PasswordToken[]

  @@index([email, name])
}

model EmailVerification {
  id      String   @id @default(cuid())
  token   String   @unique
  expires DateTime
  userId  String   @unique
  user    User     @relation(fields: [userId], references: [id])

  @@index([token])
}

model PasswordToken {
  id      String   @id @default(cuid())
  email   String
  token   String   @unique
  expires DateTime
  userId  String
  user    User     @relation(fields: [userId], references: [id])

  @@unique([email, token])
}

enum UserType {
  UNSET
  SUPPLIER
  PLUG
}

model Supplier {
  id           String    @id @default(cuid())
   businessName   String   @default("")                
  businessType String? 
   pickupLocation String    @default("") 
   phone           String                 
  avatar         String?   
  userId       String    @unique
  user         User      @relation(fields: [userId], references: [id])
  products     Product[]
  verified     Boolean   @default(false)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model Plug {
  id              String   @id @default(cuid())
  businessName    String
  phone           String?
  state           String?
  aboutBusiness   String?
  niches          String[] // Array of strings
  generalMerchant Boolean
  plugProduct  PlugProduct[]
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([businessName])
}

model Product {
  id              String           @id @default(cuid())
  name            String
  description     String
  price           Float            // Base price (can be overridden by variants)
  category        String?
  images          String?          // Typically would store JSON or comma-separated strings with image paths
  supplierId      String
   size         String?
  color        String?
  stock        Int      @default(0)
  weight       Float?   // Weight in grams
  dimensions   String? 
  plugsCount      Int              @default(0)  // Counter for number of plugs using this product
  supplier        Supplier         @relation(fields: [supplierId], references: [id])
  variations      ProductVariation[]
  plugProducts    PlugProduct[]    // Relationship to track which plugs are using this product
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  // indexes to improve query performance
  @@index([price])
  @@index([category])
  @@index([createdAt])
  @@index([supplierId])
  // Compound index for common filter combinations
  @@index([category, price])
  @@index([plugsCount]) // Index for the plugs count for efficient querying
}

model ProductVariation {
  id           String   @id @default(cuid())
  size         String?
  color        String?
  price        Float?   // Override price if specific to this variation
  stock        Int      @default(0)
  weight       Float?   // Weight in grams
  dimensions   String?  // JSON string containing dimensions: {length, width, height, unit}
  productId    String
  product      Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([productId])
  @@index([size, color])
}



model PlugProduct {
  id               String        @id @default(cuid())
  //  name             String        // new field for product name
  originalId       String
  plugId           String
  price            Float
  pendingPrice     Float?        // New field for scheduled price
  priceEffectiveAt DateTime?     // New field for effective date
    lastPriceUpdateAt DateTime?    // New field to track when a price was actually updated
  plug             Plug          @relation(fields: [plugId], references: [id], onDelete: Cascade)
 originalProduct  Product    @relation(fields: [originalId], references: [id], onDelete: Cascade) // Add onDelete: Cascade here
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@unique([plugId, originalId]) // Ensure a plug can't add the same product twice
  @@index([plugId])
  @@index([originalId]) // Index for efficient lookup of original products
}
